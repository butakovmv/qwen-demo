root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = 120

[*.{kt,kts}]
indent_size = 4
ktlint_standard = enabled

[*.{ts,js,vue}]
indent_size = 2
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[**/gradle.properties]
indent_style = space
indent_size = unset

[**/Makefile]
indent_style = tab
